---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';
import Icon from '@components/ui/icons/Icon.astro';
import { withBase } from '@utils/path';

const pageTitle: string = `Products | ${SITE.title}`;
const metaDescription =
  'Explore Mylonics hardware products for embedded systems and industrial applications. Contact us to enquire about availability and custom configurations.';

const products = [
  {
    id: 'bmp-debug-probe',
    title: 'BMP Debug Probe',
    badge: 'Open Hardware',
    description:
      'A compact, open-source Black Magic Probe compatible debug adapter for ARM Cortex-M targets. Supports SWD and JTAG, works out-of-the-box with GDB, and is designed for reliable use in production test fixtures as well as day-to-day development.',
    features: [
      'SWD & JTAG support',
      'USB-C connectivity',
      'GDB server built in – no separate software required',
      'Compatible with Zephyr IDE and standard toolchains',
      'Open hardware design',
    ],
    icon: 'tools',
  },
  {
    id: 'custom-pcb-modules',
    title: 'Custom PCB Modules',
    badge: 'Made to Order',
    description:
      'We design and manufacture custom PCB modules tailored to your application — from sensor breakout boards and power management modules to full single-board computers. Each design goes through full DFM review and is tested before shipment.',
    features: [
      'Application-specific design',
      'DFM review included',
      'Prototype and small-batch production',
      'Full test coverage',
      'Ongoing design support',
    ],
    icon: 'sparks',
  },
  {
    id: 'industrial-io-board',
    title: 'Industrial I/O Board',
    badge: 'Enquire',
    description:
      'A ruggedized I/O expansion board for industrial control applications. Provides isolated digital I/O, analog inputs, RS-485, and CAN interfaces in a DIN-rail-mountable form factor. Ideal for PLCs, gateways, and data-acquisition systems.',
    features: [
      'Isolated digital I/O (8 in / 8 out)',
      '4× differential analog inputs (24-bit ADC)',
      'RS-485 and CAN bus interfaces',
      'Wide input power supply (9–36 V DC)',
      'DIN-rail mount, -40 °C to +85 °C operating range',
    ],
    icon: 'dashboard',
  },
];
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://mylonics.com/products',
    url: 'https://mylonics.com/products',
    name: pageTitle,
    description: metaDescription,
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://mylonics.com',
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: 'en-US',
  }}
>
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="mx-auto max-w-2xl text-center">
      <h1
        class="text-3xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
      >
        Products
      </h1>
      <p class="mt-4 text-pretty text-lg text-neutral-600 dark:text-neutral-400">
        Hardware designed and built by Mylonics for embedded systems and industrial applications.
        Contact us to enquire about pricing, availability, or custom configurations.
      </p>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-3">
      {
        products.map(product => (
          <div
            id={product.id}
            class="flex flex-col rounded-xl border border-neutral-200 bg-white shadow-sm dark:border-neutral-700 dark:bg-neutral-800"
          >
            <div class="flex flex-col p-6 grow">
              <div class="flex items-start justify-between gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-blue-100 text-blue-600 dark:bg-blue-900/40 dark:text-blue-400">
                  <Icon name={product.icon} />
                </div>
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-semibold text-neutral-600 dark:bg-neutral-700 dark:text-neutral-300">
                  {product.badge}
                </span>
              </div>
              <h2 class="mt-4 text-xl font-bold text-neutral-800 dark:text-neutral-200">
                {product.title}
              </h2>
              <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
                {product.description}
              </p>
              <ul class="mt-4 grow space-y-2">
                {product.features.map(feature => (
                  <li class="flex items-start gap-2 text-sm text-neutral-600 dark:text-neutral-400">
                    <Icon name="checkCircle" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="border-t border-neutral-200 p-6 dark:border-neutral-700">
              <a
                href={withBase('/contact')}
                class="inline-flex w-full items-center justify-center gap-x-2 rounded-full bg-blue-500 px-6 py-3 text-sm font-bold text-white transition duration-300 hover:bg-blue-400 dark:bg-blue-600 dark:hover:bg-blue-500"
              >
                <Icon name="envelopeOpen" />
                Enquire
              </a>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 rounded-xl bg-neutral-100 p-8 dark:bg-neutral-800/60">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-200">
          Need Something Custom?
        </h2>
        <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
          We specialize in designing and building hardware tailored to specific applications.
          Tell us about your requirements and we'll work with you to find the right solution.
        </p>
        <a
          href={withBase('/contact')}
          class="mt-6 inline-flex items-center gap-x-2 rounded-full border border-blue-500 bg-transparent px-6 py-3 text-base font-bold text-blue-500 transition duration-300 hover:bg-blue-50 dark:border-blue-400 dark:text-blue-400 dark:hover:bg-blue-900/20"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </section>
</MainLayout>
