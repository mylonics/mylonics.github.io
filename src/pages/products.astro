---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://mylonics.com/products',
    url: 'https://mylonics.com/products',
    name: pageTitle,
    description: metaDescription,
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://mylonics.com',
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: 'en-US',
  }}
>
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="mx-auto max-w-2xl text-center">
      <h1
        class="text-3xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
      >
        Products
      </h1>
      <p class="mt-4 text-pretty text-lg text-neutral-600 dark:text-neutral-400">
        Hardware designed and built by Mylonics for embedded systems and industrial applications.
        Contact us to enquire about pricing, availability, or custom configurations.
      </p>
    </div>

    <div class="mt-16 flex flex-col items-center justify-center rounded-xl border border-dashed border-neutral-300 bg-neutral-50 py-24 text-center dark:border-neutral-700 dark:bg-neutral-800/40">
      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-blue-100 text-blue-500 dark:bg-blue-900/40 dark:text-blue-400">
        <Icon name="rocket" />
      </div>
      <h2 class="mt-6 text-2xl font-bold text-neutral-800 dark:text-neutral-200">
        Coming Soon
      </h2>
      <p class="mt-3 max-w-sm text-pretty text-neutral-600 dark:text-neutral-400">
        We are working on exciting new products. Check back soon or contact us to discuss your
        requirements in the meantime.
      </p>
      <a
        href={withBase('/contact')}
        class="mt-8 inline-flex items-center gap-x-2 rounded-full bg-blue-500 px-6 py-3 text-base font-bold text-white transition duration-300 hover:bg-blue-400 dark:bg-blue-600 dark:hover:bg-blue-500"
      >
        <Icon name="envelopeOpen" />
        Contact Us
      </a>
    </div>
  </section>
</MainLayout>
