---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';
import Icon from '@components/ui/icons/Icon.astro';
import { withBase } from '@utils/path';

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  'Mylonics offers embedded systems design services including industrial automation, field robotics, analog sensing, wireless IoT communication, firmware development, and general electrical systems design.';

const services = [
  {
    id: 'industrial-automation',
    icon: 'tools',
    title: 'Industrial Automation',
    description:
      'We design and build custom industrial control systems to meet demanding operational requirements. Our expertise covers motor controllers, PLCs, HMIs, sensors, and communication systems that help automate processes and reduce operational costs.',
  },
  {
    id: 'field-robotics',
    icon: 'rocket',
    title: 'Field Robotics',
    description:
      'End-to-end design of robotic systems for remote and field applications. We have extensive experience with robotic payloads, actuation systems, autonomous navigation, and the ruggedized electronics required for unattended operation in challenging environments.',
  },
  {
    id: 'analog-sensing',
    icon: 'dashboard',
    title: 'Analog Sensing',
    description:
      'Precision analog front-end and sensor interface design. From signal conditioning and low-noise amplification to ADC integration and calibration, we bring rigorous engineering to ensure your measurement chain delivers accurate and reliable data.',
  },
  {
    id: 'wireless-communication',
    icon: 'earth',
    title: 'Wireless Communication (IoT)',
    description:
      'Full-stack wireless connectivity solutions including Wi-Fi, Bluetooth, LoRa, Zigbee, and cellular. We design the RF hardware, select the right protocol, and develop the firmware needed to connect your device securely to the cloud or to other nodes in the field.',
  },
  {
    id: 'firmware-development',
    icon: 'hammer',
    title: 'Firmware Development',
    description:
      'Robust, maintainable embedded firmware built on modern frameworks including Zephyr RTOS. We set up complete development environments, CI/CD pipelines, and device-specific BSPs so your team can develop and deploy with confidence.',
  },
  {
    id: 'electrical-systems-design',
    icon: 'sparks',
    title: 'General Electrical Systems Design',
    description:
      'Schematic capture, PCB layout, BOM management, and design-for-manufacture reviews for single-board computers, power systems, mixed-signal hardware, and complex multi-board assemblies. From prototype to production, we support every stage of the hardware lifecycle.',
  },
];
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://mylonics.com/services',
    url: 'https://mylonics.com/services',
    name: pageTitle,
    description: metaDescription,
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://mylonics.com',
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: 'en-US',
  }}
>
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="mx-auto max-w-2xl text-center">
      <h1
        class="text-3xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
      >
        Our Services
      </h1>
      <p class="mt-4 text-pretty text-lg text-neutral-600 dark:text-neutral-400">
        We provide comprehensive embedded systems and electrical engineering services. Our team
        works closely with clients to deliver solutions that are technically sound and commercially
        viable.
      </p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map(service => (
          <div
            id={service.id}
            class="group flex flex-col rounded-xl border border-neutral-200 bg-white p-6 shadow-sm transition duration-300 hover:shadow-md dark:border-neutral-700 dark:bg-neutral-800"
          >
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100 text-blue-600 dark:bg-blue-900/40 dark:text-blue-400">
              <Icon name={service.icon} />
            </div>
            <h2 class="text-xl font-bold text-neutral-800 dark:text-neutral-200">
              {service.title}
            </h2>
            <p class="mt-3 grow text-pretty text-neutral-600 dark:text-neutral-400">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>

    <div class="mt-16 rounded-xl bg-blue-50 p-8 text-center dark:bg-blue-900/20">
      <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-200">
        Ready to Start Your Project?
      </h2>
      <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
        Whether you are a startup or an established business, we'd love to hear about your
        project.
      </p>
      <a
        href={withBase('/contact')}
        class="mt-6 inline-flex items-center gap-x-2 rounded-full bg-blue-500 px-6 py-3 text-base font-bold text-white transition duration-300 hover:bg-blue-400 dark:bg-blue-600 dark:hover:bg-blue-500"
      >
        Contact Us
      </a>
    </div>
  </section>
</MainLayout>
