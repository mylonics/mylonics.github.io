---
// BrandLogo for Mylonics
import { Image } from 'astro:assets';
import logoImg from '@images/mylonics-logo.png';
const { class: className, ...rest } = Astro.props;
---
<div class={`flex items-center gap-2 ${className ?? ''}`} {...rest}>
  <Image
    src={logoImg}
    alt="Mylonics"
    class="h-full w-auto dark:brightness-0 dark:invert"
  />
  <span class="text-xl font-bold text-neutral-800 dark:text-neutral-200">mylonics</span>
</div>
