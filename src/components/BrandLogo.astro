---
// BrandLogo for Mylonics
import { Image } from 'astro:assets';
import logoImg from '@images/mylonics-logo.png';
const { class: className, ...rest } = Astro.props;
---
<Image
  src={logoImg}
  alt="Mylonics"
  class={`h-10 w-auto dark:brightness-0 dark:invert ${className ?? ''}`}
  {...rest}
/>
